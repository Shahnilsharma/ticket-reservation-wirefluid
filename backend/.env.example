# Server
NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Frontend origin(s). Comma-separated for multiple origins.
CORS_ORIGIN=https://ticket-reservation-wirefluid.vercel.app

# Contract sync
WIREFLUID_CONTRACT_ADDRESS=0x5D21dA3Fd25Af95f6b26E8b8784C431E06D5A940
WIREFLUID_RPC_URL=https://evm.wirefluid.com
CONTRACT_SYNC_INTERVAL_MS=30000
CONTRACT_SYNC_BATCH_SIZE=150
CONTRACT_START_BLOCK=0

# Runtime startup flags
RUN_DB_PUSH_ON_START=false
RUN_MIGRATIONS_ON_START=false
